{
  "version": 2,
  "builds": [
    {
      "src": "frontend/templates/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/static/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/frontend/static/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/api"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/templates/index.html"
    }
  ]
}